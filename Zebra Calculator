<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <title>AI Impact Tracker</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0f0f0f;
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
      box-sizing: border-box;
    }

    .box {
      background: #1e1e1e;
      padding: 20px;
      border-radius: 12px;
      width: 420px;
      box-sizing: border-box;
    }

    .section {
      background: #2a2a2a;
      padding: 10px;
      border-radius: 8px;
      margin-top: 10px;
    }

    input, button {
      width: 100%;
      padding: 10px;
      margin-top: 8px;
      border-radius: 6px;
      border: none;
      box-sizing: border-box;
    }

    button {
      background: #4caf50;
      color: white;
      cursor: pointer;
    }

    button:hover {
      background: #45a049;
    }

    .reset {
      background: #d32f2f;
    }

    .reset:hover {
      background: #b71c1c;
    }

    .stats {
      margin-top: 15px;
      font-size: 14px;
      line-height: 1.5;
    }

    .bar {
      height: 10px;
      background: #333;
      border-radius: 5px;
      overflow: hidden;
      margin-top: 5px;
    }

    .bar-fill {
      height: 100%;
      background: #4caf50;
    }

    .hint {
      font-size: 12px;
      opacity: 0.6;
      margin-top: 5px;
    }
  </style>
</head>

<body>

<div class="box">
  <h2>AI Impact Tracker 🌍💧🦓</h2>

  <div class="section">
    <b>🖼️ Obrazy AI</b>
    <input type="number" id="images" />
  </div>

  <div class="section">
    <b>💬 Zwykłe odpowiedzi</b>
    <input type="number" id="simple" />
  </div>

  <div class="section">
    <b>🧠 Głębokie myślenie</b>
    <input type="number" id="deep" />
  </div>

  <button onclick="calculate()">Dodaj sesję</button>
  <button class="reset" onclick="reset()">Reset historii</button>

  <div class="stats" id="stats"></div>
</div>

<script>
  // 💧 MODEL WODY
  const WATER_IMAGE = 0.5;
  const WATER_SIMPLE = 0.01;
  const WATER_DEEP = 0.08;

  // 🦓 MODEL ZEBRY
  const ZEBRA_WATER = 50;

  let data = {
    water: 0,
    zebras: 0,
    sessions: []
  };

  // 🔧 ładne formatowanie liczb (bez zbędnych zer)
  function formatNumber(num) {
    return Number(num.toFixed(3)).toString();
  }

  function calculate() {
    const images = Number(document.getElementById("images").value || 0);
    const simple = Number(document.getElementById("simple").value || 0);
    const deep = Number(document.getElementById("deep").value || 0);

    const water =
      images * WATER_IMAGE +
      simple * WATER_SIMPLE +
      deep * WATER_DEEP;

    const zebras = water / ZEBRA_WATER;

    data.water += water;
    data.zebras += zebras;

    data.sessions.push({ images, simple, deep, water, zebras });

    update();
  }

  function reset() {
    data = {
      water: 0,
      zebras: 0,
      sessions: []
    };
    update();
  }

  function update() {
    const last = data.sessions.slice(-1)[0];

    document.getElementById("stats").innerHTML = `
      <p>💧 Woda łącznie: <b>${formatNumber(data.water)} L</b></p>
      <p>🦓 Zebry łącznie: <b>${formatNumber(data.zebras)}</b></p>

      <div style="margin-top:10px;">
        <b>📊 Ostatnia sesja</b>
        ${last ? `
          <p>🖼️ obrazy: ${last.images}</p>
          <p>💬 zwykłe: ${last.simple}</p>
          <p>🧠 głębokie: ${last.deep}</p>
          <p>💧 woda: ${formatNumber(last.water)} L</p>
          <p>🦓 zebry: ${formatNumber(last.zebras)}</p>
        ` : "<p>Brak danych</p>"}
      </div>

      <div style="margin-top:10px;">
        <b>🔥 Wpływ AI</b>
        <div class="bar">
          <div class="bar-fill" style="width:${Math.min(data.zebras * 10, 100)}%"></div>
        </div>
      </div>

      <div class="hint">1 zebra ≈ 50L wody (model edukacyjny)</div>
    `;
  }
</script>

</body>
</html>
